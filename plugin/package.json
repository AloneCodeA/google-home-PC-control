{
  "name": "matterbridge-google-home-screen-control",
  "version": "1.0.0",
  "description": "Local Matter control for Windows display power",
  "author": "Alone",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/module.js",
  "types": "dist/module.d.ts",
  "exports": {
    ".": {
      "import": "./dist/module.js",
      "types": "./dist/module.d.ts"
    }
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "files": [
    "dist",
    "bin",
    "matterbridge-google-home-screen-control.config.json",
    "matterbridge-google-home-screen-control.schema.json"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --reporter verbose",
    "test:coverage": "vitest run --coverage",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@vitest/coverage-istanbul": "4.1.8",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
